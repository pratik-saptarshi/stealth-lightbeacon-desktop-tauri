{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stealth Lightbeacon",
  "version": "0.1.1",
  "identifier": "com.stealth.lightbeacon",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Stealth Lightbeacon",
        "width": 800,
        "height": 600,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true
  }
}
